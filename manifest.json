{
  "manifest_version": 3,
  "name": "claukit",
  "version": "0.5.0",
  "browser_specific_settings": {
    "gecko": {
      "id": "{39ffe967-03f6-44e0-8cc6-13b6c3a6093e}",
      "strict_min_version": "142.0",
      "data_collection_permissions": { "required": ["none"] }
    }
  },
  "description": "your claude companion. tokens, cache, usage — all in one spot.",
  "action": {
    "default_title": "claukit"
  },
  "content_scripts": [
    {
      "matches": ["https://claude.ai/*"],
      "css": ["src/styles.css"],
      "js": [
        "src/vendor/o200k_base.js",
        "dist/content.js"
      ]
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["dist/bridge.js"],
      "matches": ["https://claude.ai/*"]
    }
  ]
}
